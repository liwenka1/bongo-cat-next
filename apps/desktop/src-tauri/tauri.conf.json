{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BongoCat Manager",
  "version": "0.2.16",
  "identifier": "com.mypetassistant.desktop",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "BongoCat Manager",
        "url": "/",
        "width": 1480,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 760,
        "center": true,
        "shadow": true,
        "alwaysOnTop": false,
        "transparent": false,
        "decorations": true,
        "resizable": true,
        "acceptFirstMouse": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "**/*"
          ],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "category": "Game",
    "shortDescription": "Desktop pet assistant with chat, tasks and local tools",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "assets/tray.png",
      "assets/logo.png",
      "assets/models",
      "resources/pet-app"
    ]
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
